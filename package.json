{
  "name": "teable-mcp",
  "version": "1.0.0",
  "description": "Full-CRUD MCP server for Teable — zero build step, npx-ready",
  "type": "module",
  "bin": {
    "teable-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/tests/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "teable",
    "claude",
    "anthropic",
    "model-context-protocol"
  ],
  "author": "Zacharia Kimotho",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Imperol3/teable-mcp.git"
  },
  "homepage": "https://github.com/Imperol3/teable-mcp#readme",
  "bugs": {
    "url": "https://github.com/Imperol3/teable-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
